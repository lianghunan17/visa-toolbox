# Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin bearer token for admin.html / admin.js
ADMIN_BEARER_TOKEN=replace-with-a-long-random-token

# Secret used to sign license auth tokens
LICENSE_TOKEN_SECRET=replace-with-a-long-random-secret

# Optional
PORT=8787
NODE_ENV=production
CORS_ORIGIN=https://your-admin-site.example.com
LEMON_SQUEEZY_WEBHOOK_SECRET=
